[debug] [2026-04-01T13:23:38.286Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/langford-system/rulesets {"name":"projects/langford-system/rulesets/650ad98a-f81d-42ec-b11a-b1482d14ba46","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // ── Helper: signed-in check ─────────────────────────────────────────────\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    // ── Helper: user role check ──────────────────────────────────────────────\n    // Note: Firestore rules don't have direct access to user roles from the users collection\n    // All authenticated users can read/write. Application-level filtering handles role-based access.\n\n    // ── All authenticated users can read/write ──────────────────────────────\n    // Data isolation is enforced at the APPLICATION level (query filters).\n    // This ensures onSnapshot / list queries always succeed for signed-in users.\n\n    match /users/{userId} {\n      allow read: if isSignedIn();\n      allow write: if isSignedIn();\n    }\n\n    match /students/{studentId} {\n      allow read, write: if isSignedIn();\n\n      match /payments/{paymentId} {\n        allow read, write: if isSignedIn();\n      }\n\n      match /activityLog/{logId} {\n        allow read, write: if isSignedIn();\n      }\n\n      match /installmentPlans/{planId} {\n        allow read, write: if isSignedIn();\n      }\n\n      match /attendance/{sessionId} {\n        allow read, write: if isSignedIn();\n      }\n\n      match /enrollments/{enrollmentId} {\n        allow read, write: if isSignedIn();\n      }\n    }\n\n    // Collection group queries\n    match /{path=**}/activityLog/{logId} {\n      allow read: if isSignedIn();\n    }\n\n    match /{path=**}/payments/{paymentId} {\n      allow read: if isSignedIn();\n    }\n\n    match /loginLogs/{logId} {\n      allow read, write: if isSignedIn();\n    }\n\n    match /courses/{courseId} {\n      allow read, write: if isSignedIn();\n    }\n\n    match /auditLog/{logId} {\n      allow read, write: if isSignedIn();\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-04-01T13:23:38.195759Z","metadata":{"services":["cloud.firestore"]}}
