rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: signed-in check ─────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    // ── Helper: user role check ──────────────────────────────────────────────
    // Note: Firestore rules don't have direct access to user roles from the users collection
    // All authenticated users can read/write. Application-level filtering handles role-based access.

    // ── All authenticated users can read/write ──────────────────────────────
    // Data isolation is enforced at the APPLICATION level (query filters).
    // This ensures onSnapshot / list queries always succeed for signed-in users.

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /students/{studentId} {
      allow read, write: if isSignedIn();

      match /payments/{paymentId} {
        allow read, write: if isSignedIn();
      }

      match /activityLog/{logId} {
        allow read, write: if isSignedIn();
      }

      match /installmentPlans/{planId} {
        allow read, write: if isSignedIn();
      }

      match /attendance/{sessionId} {
        allow read, write: if isSignedIn();
      }

      match /enrollments/{enrollmentId} {
        allow read, write: if isSignedIn();
      }
    }

    // Collection group queries
    match /{path=**}/activityLog/{logId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/payments/{paymentId} {
      allow read: if isSignedIn();
    }

    match /loginLogs/{logId} {
      allow read, write: if isSignedIn();
    }

    match /courses/{courseId} {
      allow read, write: if isSignedIn();
    }

    match /auditLog/{logId} {
      allow read, write: if isSignedIn();
    }
  }
}
